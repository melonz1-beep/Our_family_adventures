{
  "rules": {
    ".read": false,
    ".write": false,
    "families": {
      "$familyId": {
        "familyMembers": {
          "$uid": {
            ".read": "auth != null && (auth.uid == $uid || (root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin'))",
            ".write": "auth != null && ((root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin') || (auth.uid == $uid && !data.exists() && newData.child('active').val() == true && newData.child('email').val() == auth.token.email && ((newData.child('role').val() == 'Admin' && auth.token.email == root.child('families').child($familyId).child('publicData').child('settings').child('template').child('adminEmail').val()) || (newData.child('role').val() != 'Admin' && newData.child('inviteId').exists() && newData.child('inviteCode').val() == root.child('families').child($familyId).child('pendingInvites').child(newData.child('inviteId').val()).child('code').val() && auth.token.email == root.child('families').child($familyId).child('pendingInvites').child(newData.child('inviteId').val()).child('email').val()))))",
            ".validate": "!newData.exists() || (newData.hasChildren(['uid','email','role','active']) && newData.child('uid').val() == $uid && newData.child('email').isString() && (newData.child('role').val() == 'Admin' || newData.child('role').val() == 'Family' || newData.child('role').val() == 'Guest' || newData.child('role').val() == 'Child') && newData.child('active').isBoolean())"
          }
        },
        "publicData": {
          ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true",
          ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true"
        },
        "scrapbookStudioV2": {
          ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true",
          "$ownerUid": {
            "$pageId": {
              ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (auth.uid == $ownerUid || root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin')"
            }
          }
        },
        "familyTrips": {
          ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true",
          "$tripId": {
            ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (newData.exists() || root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin' || data.child('trip/ownerUid').val() == auth.uid)"
          }
        },
        "privateTrips": {
          "$tripId": {
            ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin' || data.child('trip/ownerUid').val() == auth.uid || root.child('families').child($familyId).child('tripMembers').child($tripId).child(auth.uid).val() == true)",
            ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin' || data.child('trip/ownerUid').val() == auth.uid || newData.child('trip/ownerUid').val() == auth.uid || root.child('families').child($familyId).child('tripMembers').child($tripId).child(auth.uid).val() == true)"
          }
        },
        "tripAccess": {
          "$uid": {
            ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (auth.uid == $uid || root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin')",
            "$tripId": {
              ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin' || root.child('families').child($familyId).child('privateTrips').child($tripId).child('trip/ownerUid').val() == auth.uid)"
            }
          },
          ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin'"
        },
        "tripMembers": {
          "$tripId": {
            ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin' || root.child('families').child($familyId).child('privateTrips').child($tripId).child('trip/ownerUid').val() == auth.uid)",
            ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin' || root.child('families').child($familyId).child('privateTrips').child($tripId).child('trip/ownerUid').val() == auth.uid)"
          }
        },
        "userNotifications": {
          "$uid": {
            ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (auth.uid == $uid || root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin')",
            ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (auth.uid == $uid || root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin')"
          }
        },
        "migration": {
          ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true",
          ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin'"
        },
        "appData": {
          ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin'",
          ".write": false
        },
        "pendingInvites": {
          ".indexOn": ["code", "email"],
          "$inviteId": {
            ".read": false,
            ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin'"
          }
        },
        "setup": {
          ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true",
          ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin'"
        },
        "pushTokens": {
          "$uid": {
            ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (auth.uid == $uid || root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin')",
            ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && auth.uid == $uid"
          }
        },
        "notificationQueue": {
          "$queueId": {
            ".read": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && (data.child('actorUid').val() == auth.uid || root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('role').val() == 'Admin')",
            ".write": "auth != null && root.child('families').child($familyId).child('familyMembers').child(auth.uid).child('active').val() == true && !data.exists() && newData.child('actorUid').val() == auth.uid && newData.child('targets').exists() && newData.child('text').isString()"
          }
        }
      }
    }
  }
}
