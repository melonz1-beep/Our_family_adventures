rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function verified() { return signedIn() && request.auth.token.email_verified == true; }
    function userDoc(uid) { return get(/databases/$(database)/documents/users/$(uid)); }
    function isAdmin() { return verified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc(request.auth.uid).data.role in ['admin','owner']; }

    match /users/{userId} {
      allow read: if verified() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if verified() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      match /private/{docId} {
        allow read, write: if verified() && request.auth.uid == userId;
      }
    }

    match /families/{familyId}/{document=**} {
      allow read: if verified();
      allow write: if isAdmin();
    }

    match /adventures/{tripId} {
      allow create: if verified();
      allow read: if verified() && (resource.data.visibility == 'family' || request.auth.uid in resource.data.memberUids || isAdmin());
      allow update, delete: if verified() && (request.auth.uid == resource.data.ownerUid || request.auth.uid in resource.data.adminUids || isAdmin());
    }

    match /activityLog/{logId} {
      allow read, create: if verified();
      allow update, delete: if isAdmin();
    }
  }
}
