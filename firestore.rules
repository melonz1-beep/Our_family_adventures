rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin','owner']; }
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      match /private/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }
    match /families/{familyId} {
      allow read, write: if signedIn();
      match /{document=**} {
        allow read: if signedIn();
        allow write: if signedIn();
      }
    }
    match /adventures/{tripId} {
      allow read: if signedIn() && (resource.data.visibility == 'family' || request.auth.uid in resource.data.memberUids || isAdmin());
      allow create: if signedIn();
      allow update, delete: if signedIn() && (request.auth.uid == resource.data.ownerUid || request.auth.uid in resource.data.adminUids || isAdmin());
    }
    match /activityLog/{logId} { allow read, create: if signedIn(); allow update, delete: if isAdmin(); }
  }
}
