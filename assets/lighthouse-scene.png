:root{--ocean:#092231;--ocean2:#0b3045;--cream:#fff7ea;--paper:#fffaf2;--sand:#ead8bd;--gold:#d3a354;--gold2:#f2d89a;--ink:#092231;--muted:#596771;--shadow:0 18px 50px rgba(6,24,35,.18)}*{box-sizing:border-box}html,body,#app{width:100%;max-width:100%;overflow-x:hidden}body{margin:0;min-height:100svh;font-family:Georgia,'Times New Roman',serif;background:var(--cream);color:var(--ink)}button,input,textarea,select{font:inherit}button{cursor:pointer}.screen{display:none;min-height:100svh}.screen.active{display:block}.splash{position:fixed;inset:0;z-index:30;display:none;place-items:end center;text-align:center;color:white;overflow:hidden;padding:24px 20px calc(96px + env(safe-area-inset-bottom))}.splash.active{display:grid}.photo-layer{position:absolute;inset:0;background:url('assets/lighthouse-home.png') center/cover no-repeat;transform:scale(1.01)}.home-photo{background-image:url('assets/lighthouse-scene.png');background-position:center top}.veil{position:absolute;inset:0;background:linear-gradient(180deg,rgba(5,19,29,.04),rgba(5,19,29,.18) 45%,rgba(5,19,29,.72))}.splash-veil{background:linear-gradient(180deg,rgba(5,19,29,.02),rgba(5,19,29,.05) 40%,rgba(5,19,29,.62))}.home-veil{background:linear-gradient(180deg,rgba(5,19,29,.06),rgba(5,19,29,.33),rgba(5,19,29,.74))}.beam{position:absolute;top:17%;right:10%;width:44vw;height:150px;background:linear-gradient(90deg,rgba(255,232,169,0),rgba(255,232,169,.25),rgba(255,232,169,0));clip-path:polygon(100% 48%,0 0,0 100%,100% 55%);animation:beam 16s ease-in-out infinite;opacity:0}.waves{position:absolute;left:0;right:0;bottom:0;height:110px;overflow:hidden;background:linear-gradient(180deg,transparent,rgba(9,34,49,.58))}.waves.short{height:70px}.waves span{position:absolute;left:-10%;bottom:-42px;width:120%;height:78px;border-radius:50% 50% 0 0;background:radial-gradient(70% 90% at 50% 0,rgba(255,255,255,.48),rgba(255,255,255,.12) 45%,rgba(13,59,79,.08));animation:wave 9s ease-in-out infinite}.waves span:nth-child(2){bottom:-53px;opacity:.55;animation-duration:12s}.waves span:nth-child(3){bottom:-62px;opacity:.35;animation-duration:15s}.splash-content{position:relative;z-index:2;width:min(680px,100%);animation:rise 1.2s ease both}.splash-content.minimal{align-self:end}.kicker{text-transform:uppercase;letter-spacing:.22em;color:var(--gold2);font-weight:900;font-size:.76rem}.tagline{font-size:1.2rem;max-width:620px;margin:0 auto 28px}.gold-btn,.navy-btn{border:0;border-radius:999px;padding:13px 20px;font-weight:900}.gold-btn{background:linear-gradient(135deg,#c89137,#f4dc9f);color:#082233;box-shadow:0 14px 36px rgba(0,0,0,.2)}.gold-btn.big{font-size:1.15rem;padding:16px 34px}.navy-btn{background:var(--ocean);color:white}.hero{position:relative;min-height:min(78svh,620px);border-radius:0 0 38px 38px;overflow:hidden;color:white;box-shadow:var(--shadow)}.icon-btn{position:absolute;z-index:5;top:18px;border:0;width:48px;height:48px;border-radius:50%;background:rgba(9,34,49,.78);color:white;backdrop-filter:blur(10px);font-size:1.35rem}.splash-menu{left:18px}.splash-bell{right:18px}.menu-open{left:18px}.heart-btn{right:18px}.hero-copy{position:relative;z-index:3;padding:112px 22px 34px;width:min(760px,100%)}.hero-copy.compact{padding-top:160px}.hero h2{font-size:clamp(2.7rem,12vw,5.6rem);line-height:.9;margin:0 0 12px;text-shadow:0 4px 28px rgba(0,0,0,.35)}.hero p{font-size:1.1rem}.countdown{display:inline-block;margin-top:12px;background:rgba(255,250,242,.92);color:var(--ocean);border-radius:999px;padding:12px 18px;font-weight:900}.content{padding:22px 16px 104px;width:min(1040px,100%);margin:auto}.daily-card,.panel{background:rgba(255,250,242,.96);border:1px solid rgba(255,255,255,.8);box-shadow:var(--shadow);border-radius:28px;padding:20px;margin-bottom:16px}.daily-card h3,.panel h3{margin-top:0;color:var(--ocean)}.scroll-row{display:grid;grid-auto-flow:column;grid-auto-columns:minmax(235px,72vw);gap:14px;overflow-x:auto;padding:4px 2px 18px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch}.feature-card{scroll-snap-align:start;min-height:150px;text-align:left;border:0;border-radius:26px;background:var(--paper);box-shadow:0 10px 28px rgba(9,34,49,.12);padding:20px}.feature-card b{display:block;font-size:1.12rem;margin-bottom:8px}.feature-card span,.small,.panel p{color:var(--muted);line-height:1.4}.bottom-nav{position:fixed;left:0;right:0;bottom:0;z-index:20;display:flex;overflow-x:auto;justify-content:flex-start;gap:2px;background:rgba(255,250,242,.97);border-top:1px solid rgba(211,163,84,.28);box-shadow:0 -10px 25px rgba(6,24,35,.08);padding-bottom:env(safe-area-inset-bottom);-webkit-overflow-scrolling:touch}.bottom-nav button{flex:0 0 auto;min-width:82px;border:0;background:transparent;color:var(--ocean);font-size:.78rem;font-weight:900;padding:12px 2px}.page{background:linear-gradient(180deg,var(--cream),var(--sand));min-height:100svh;padding:18px 15px calc(110px + env(safe-area-inset-bottom))}.page-head{width:min(960px,100%);margin:0 auto 14px}.back{border:0;border-radius:999px;background:var(--paper);padding:10px 14px;color:var(--ocean);font-weight:900;box-shadow:0 8px 20px rgba(9,34,49,.1)}.page h2{font-size:clamp(2.1rem,8vw,4rem);line-height:1;margin:18px 0;color:var(--ocean)}.panel{width:min(900px,100%);margin-left:auto;margin-right:auto}.hero-panel{background:linear-gradient(180deg,rgba(255,250,242,.98),rgba(251,237,216,.96))}.panel-sub{background:rgba(234,216,189,.35);border-radius:20px;padding:14px;margin:10px 0}input,textarea,select{width:100%;border:1px solid #dac5a5;border-radius:18px;padding:13px 14px;background:white;margin:6px 0;color:var(--ink)}textarea{min-height:90px}.grid2,.wizard-grid{display:grid;gap:10px}.check{display:flex;gap:10px;align-items:center;margin:8px 0}.check input{width:auto}.list,.cards{max-width:900px;margin:auto;display:grid;gap:12px}.cards{grid-template-columns:1fr}.item,.person,.memory,.chat{background:var(--paper);border-radius:22px;padding:16px;box-shadow:0 8px 22px rgba(9,34,49,.1)}.item-actions,.chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}.mini-btn,.chip{border:0;border-radius:999px;background:#ead8bd;color:var(--ocean);padding:8px 12px;font-weight:900}.chip input{width:auto;margin:0 6px 0 0}.danger{background:#ead1c8}.avatar{width:62px;height:62px;border-radius:50%;object-fit:cover;background:#ead8bd;display:inline-grid;place-items:center;margin-right:12px;flex:0 0 auto}.person{display:flex;align-items:center;justify-content:space-between;gap:12px}.person-main{display:flex;align-items:center}.person small{display:block;color:var(--muted)}.chat-list{display:grid;gap:10px;min-height:180px}.chat{max-width:88%;border-radius:22px 22px 22px 6px}.chat-row{display:flex;gap:8px}.chat-row input{margin:0}.tabs{width:min(900px,100%);margin:0 auto 14px;display:flex;gap:8px;overflow-x:auto}.tab{border:0;background:var(--paper);border-radius:999px;padding:10px 14px;font-weight:900;color:var(--ocean)}.tab.active{background:var(--ocean);color:white}.tab-pane{display:none}.tab-pane.active{display:block}.map-card{width:min(900px,100%);margin:0 auto 16px;background:var(--paper);border-radius:28px;padding:14px;box-shadow:var(--shadow)}.map-bg{position:relative;height:240px;border-radius:22px;background:linear-gradient(135deg,#dce9e5,#f4dca8 55%,#8eb0b3);overflow:hidden}.map-bg:before{content:'';position:absolute;inset:18px;border:2px dashed rgba(9,34,49,.18);border-radius:45% 55% 40% 60%}.pin{position:absolute;font-size:1.8rem;filter:drop-shadow(0 8px 8px rgba(0,0,0,.25))}.p1{left:18%;top:28%}.p2{left:64%;top:20%}.p3{left:45%;top:58%}.p4{left:77%;top:68%}.timeline .item{border-left:5px solid var(--gold)}.drawer{position:fixed;z-index:50;inset:0 auto 0 0;width:min(330px,86vw);background:var(--paper);box-shadow:var(--shadow);padding:22px;transform:translateX(-105%);transition:.25s ease}.drawer.open{transform:translateX(0)}.drawer button:not(.drawer-close){display:block;width:100%;text-align:left;border:0;background:white;border-radius:16px;padding:13px;margin:8px 0;color:var(--ocean);font-weight:900}.drawer-close{float:right;border:0;background:var(--ocean);color:white;border-radius:50%;width:36px;height:36px}.scrim{position:fixed;z-index:40;inset:0;background:rgba(0,0,0,.25);display:none}.scrim.show{display:block}.note{margin-top:12px}.item a{color:var(--ocean);font-weight:900;text-decoration-thickness:2px}.journal-entry{border-left:5px solid var(--gold)}@keyframes beam{0%,70%,100%{opacity:0;transform:rotate(-7deg)}80%{opacity:.5;transform:rotate(3deg)}}@keyframes wave{50%{transform:translateX(3%) translateY(-12px)}}@keyframes rise{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}@media(min-width:720px){.grid2,.wizard-grid{grid-template-columns:1fr 1fr}.bottom-nav button{font-size:.82rem}.hero-copy{padding-left:8vw}.scroll-row{grid-auto-columns:minmax(260px,300px)}.cards{grid-template-columns:repeat(2,minmax(0,1fr))}.hero{min-height:560px}}@media(max-width:480px){.hero-copy h2{font-size:clamp(2.35rem,14vw,4rem)}.hero-copy{padding:112px 18px 28px}.hero-copy.compact{padding-top:145px}.daily-card,.feature-card,.panel{border-radius:24px}.page{padding-left:14px;padding-right:14px}.gold-btn.big{width:min(360px,100%)}}

/* v3.3 polish: crop embedded artwork cards on the splash image and keep the splash separate from home content */
.splash .photo-layer{transform:scale(1.18);background-position:center 34%;}
.splash .splash-content{padding-bottom:clamp(80px,14svh,150px)}
.memory-preview,.cover-thumb{width:100%;max-height:240px;object-fit:cover;border-radius:18px;margin-bottom:12px;box-shadow:0 10px 24px rgba(9,34,49,.12)}
.cover-thumb{max-height:160px}
@media(max-width:480px){.splash .photo-layer{transform:scale(1.22);background-position:center 38%;}.splash .splash-content{padding-bottom:120px}}

.notification small{display:block;color:var(--muted);margin-top:6px}.notification.read{opacity:.72}.badge{position:absolute;right:-4px;top:-4px;background:#d3a354;color:#092231;border-radius:999px;font-size:.68rem;padding:2px 6px;font-weight:900}.notify-actions{display:flex;gap:10px;flex-wrap:wrap;margin:12px 0}.notify-open{position:absolute}


/* v3.5 splash + people fixes */
body.show-splash .bottom-nav{display:none}
body.show-splash{overflow:hidden}
.splash .gold-btn.big{opacity:0;animation:buttonIn .7s ease forwards 1.15s}
@keyframes buttonIn{to{opacity:1;transform:none}}
.splash .photo-layer{transform:scale(1.42);background-position:center 28%;}
.splash:after{content:'';position:absolute;left:0;right:0;bottom:0;height:34svh;background:linear-gradient(180deg,rgba(5,19,29,0),rgba(5,19,29,.45) 38%,rgba(5,19,29,.82));pointer-events:none;z-index:1}
.splash-content{z-index:2}
label{display:block;color:var(--ocean);font-weight:900;line-height:1.15}
label input,label select,label textarea{font-weight:400;color:var(--ink)}
.feature-card{position:relative;z-index:1;touch-action:manipulation}
@media(max-width:480px){.splash .photo-layer{transform:scale(1.55);background-position:center 25%;}.splash .splash-content{padding-bottom:150px}.hero{min-height:72svh}.content{margin-top:0}}


/* Build 3.6 - Scrapbook Edition */
.scrapbook-callout{background:linear-gradient(135deg,rgba(255,250,242,.98),rgba(246,231,206,.98));border:1px solid rgba(211,163,84,.32)}
.scrapbook-intro{background:linear-gradient(135deg,var(--ocean),#123a50);color:#fff8ec}.scrapbook-intro h3{color:#fff8ec}.scrapbook-intro p{color:#f7ead5}
.scrapbook-grid{display:grid;gap:18px}.scrap-page{background:#fffaf2;border-radius:28px;box-shadow:var(--shadow);overflow:hidden;border:1px solid rgba(211,163,84,.24)}
.scrap-media{width:100%;max-height:330px;object-fit:cover;display:block}.scrap-placeholder{min-height:210px;display:grid;place-items:center;font-size:4rem;background:linear-gradient(135deg,#ead8bd,#fff7ea)}
.scrap-body{padding:20px}.scrap-body h3{margin:0 0 8px;color:var(--ocean)}.scrap-body .mini-btn button{border:0;background:transparent;color:var(--ocean);font-weight:900}
.scrap-page.vintage{background:#f8ead7}.scrap-page.rustic{background:#f0dfc8}.scrap-page.christmas{background:#fffaf2;border-color:#9e3028}.scrap-page.mountains{background:#edf2ec}.scrap-page.modern{background:#ffffff}
@media(min-width:820px){.scrapbook-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.scrap-page{display:grid;grid-template-rows:auto 1fr}}


/* Build 3.7 scrapbook + memories polish */
.bottom-nav{display:none !important;}
.page{padding-bottom:32px !important;}
.memory-preview,.scrap-media{object-fit:contain !important;background:#f8edda;}
.memory,.scrap-page{overflow:hidden;}
.scrap-page{position:relative;}
.scrap-page.full .scrap-media{min-height:360px;width:100%;background:#0b3045;}
.scrap-page.collage{display:grid;grid-template-columns:1fr;}
.scrap-page.journal .scrap-media{max-height:180px;}
.print-badge{display:inline-block;border-radius:999px;background:#fff7ea;color:#092231;padding:6px 10px;font-weight:900;margin:2px;}
.contact-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}
.contact-actions a{text-decoration:none;}
@media print{body{background:white}.drawer,.scrim,.bottom-nav,.page-head,.item-actions,.back,.icon-btn,.splash{display:none!important}.screen{display:block!important;min-height:auto}.home,.page:not(#scrapbook){display:none!important}.scrapbook-page{display:block!important;background:white}.scrap-page{break-inside:avoid;box-shadow:none;border:1px solid #d8c6aa;margin:0 0 18px}.panel{box-shadow:none}.scrap-media{max-height:480px;object-fit:contain!important}}
