rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function verified() { return request.auth != null && request.auth.token.email_verified == true; }
    match /family/{userId}/{allPaths=**} {
      allow read: if verified();
      allow write: if verified() && request.auth.uid == userId
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*|application/pdf');
      allow delete: if verified() && request.auth.uid == userId;
    }
  }
}
