rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Basic authenticated access. Tighten per-family/trip membership once user IDs are fully mapped in the app.
    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
